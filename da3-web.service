# DA3 Web 8060 服务的 systemd 单元（可选）。
# 安装：sudo cp da3-web.service /etc/systemd/system/ && sudo systemctl daemon-reload
#       sudo systemctl enable --now da3-web.service
# 查日志：journalctl -u da3-web -f
[Unit]
Description=DA3 Web (Depth Anything 3 深度图 + 电子秤) 8060 服务
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=odyss
WorkingDirectory=/home/odyss/da3-web
ExecStart=/home/odyss/da3-web/run.sh
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
