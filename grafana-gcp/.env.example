# grafana-gcp 配置样例：复制为同目录 .env 后按需改。
# up.sh / down.sh / docker compose / 隧道脚本都会读这个 .env。

# ---- 本机 Grafana（局域网访问入口） ----
# Grafana 监听端口。用 http://<本机内网IP>:${GRAFANA_PORT} 访问。
# 默认 3001：刻意避开 5090 上 LocateAnything 观测栈已占的 3000。
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- IAP 隧道：把 GCP 上 loopback 的 Prometheus 转发到本机 ----
# 本机侧隧道落地端口，Grafana 数据源即指向 127.0.0.1:${LOCAL_PROM_PORT}。
# 默认 19090：高位端口，避开 5090 上已占的 9090。
LOCAL_PROM_PORT=19090

# GCP 目标（gpu-g4-01，一般不用改；REMOTE_PROM_PORT 是 GCP 上 Prometheus 的 loopback 端口）
GCP_PROJECT=pelagic-pod-489307-g3
GCP_ZONE=asia-southeast1-b
GCP_VM=gpu-g4-01
REMOTE_PROM_PORT=9090
