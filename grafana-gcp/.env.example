# grafana-gcp 配置样例：复制为同目录 .env 后按需改（.env 不入库）。
# up.sh / down.sh / docker compose / frp 隧道脚本都会读这个 .env。

# ---- 本机 Grafana（局域网访问入口） ----
# 用 http://<本机内网IP>:${GRAFANA_PORT} 访问（在 5090 即 http://192.168.0.50:3001）。
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# ---- 数据源① 5090 本机 Prometheus（LocateAnything 观测栈的 Prometheus） ----
# 默认 9091（5090 上 9090 被 mihomo 代理占用）
LOCAL_PROM_PORT=9091

# ---- 数据源② g4-01（算力）Prometheus：经 frp STCP 隧道落地本机 ----
# 本机落地端口，Grafana 数据源② 指向 127.0.0.1:${G4_PROM_LOCAL_PORT}
G4_PROM_LOCAL_PORT=29090

# ---- frp STCP 隧道参数（连同一个 frp 服务器，把 g4-01 的 Prometheus 拉过来） ----
# frp 服务器（与 5090 现有 frpc 同一台）
FRP_SERVER_ADDR=39.106.42.60
FRP_SERVER_PORT=7000
FRP_VERSION=0.65.0
# frp 认证 token（与 5090 现有 frpc /usr/local/frp/frpc/frpc.toml 的 auth.token 一致）
FRP_TOKEN=__FILL_ME__
# STCP 密钥（与 g4-01 端 frpc 的 g4-prometheus proxy secretKey 一致）
STCP_SECRET=__FILL_ME__
# g4-01 端 STCP proxy 名（g4-01 上 frpc.toml 里的 proxy name）
STCP_SERVER_NAME=g4-prometheus
